# MineAI environment – copy to .env and edit

# ── Minecraft bot (Mineflayer) ─────────────────────────────────────────────
HOST=localhost
PORT=25565
USERNAME=MineAI
AUTH=offline          # use "microsoft" for online-mode servers
WS_PORT=3001

# ── Python agent ──────────────────────────────────────────────────────────
BOT_HOST=localhost
BOT_WS_PORT=3001

# ── llama.cpp HTTP server ──────────────────────────────────────────────────
# Start with:  ./llama-server -m <model.gguf> --port 8080 --jinja
LLM_HOST=localhost
LLM_PORT=8080
LLM_MODEL=local-model    # shown in logs – doesn't affect routing
LLM_TIMEOUT=60

# ── Generation ────────────────────────────────────────────────────────────
MAX_TOKENS=512
TEMPERATURE=0.3

# ── Agent behaviour ───────────────────────────────────────────────────────
THINK_INTERVAL=3.0       # seconds between autonomous think cycles
MAX_HISTORY=8            # how many past turns to include in the prompt

# ── Voyager-style improvements ────────────────────────────────────────────
MAX_RETRIES=2            # critic retry attempts per turn
CURRICULUM_INTERVAL=10   # run curriculum every N think cycles
SKILL_TOP_K=3            # how many library skills to retrieve per turn
SKILL_FAIL_THRESHOLD=3   # consecutive goal failures before skill generation triggers
SKILL_CHROMA_PATH=data/skill_chroma   # ChromaDB persistent directory

# ── Persistence ───────────────────────────────────────────────────────────
MEMORY_PATH=data/memory.json
