# MineAI environment – copy to .env and edit

# ── Minecraft bot (Mineflayer) ─────────────────────────────────────────────
HOST=localhost
PORT=25565
USERNAME=MineAI
AUTH=offline          # use "microsoft" for online-mode servers
WS_PORT=3001

# ── Python agent ──────────────────────────────────────────────────────────
BOT_HOST=localhost
BOT_WS_PORT=3001

# ── Local LLM  (ReAct think loop – called every THINK_INTERVAL seconds) ───
# Start with:  ./llama-server -m <model.gguf> --port 8080 --jinja
LLM_HOST=localhost
LLM_PORT=8080
LLM_MODEL=local-model    # shown in logs – doesn't affect routing
LLM_TIMEOUT=60
# LLM_API_KEY=           # leave blank for llama.cpp (no auth)

# ── Strong LLM  (curriculum, critic, skill generation – called infrequently) ─
# Option A – GitHub Models (GPT-4.1, free tier available):
#   STRONG_LLM_BASE_URL=https://models.inference.ai.azure.com
#   STRONG_LLM_MODEL=gpt-4.1
#   STRONG_LLM_API_KEY=<GitHub PAT with models:read scope>
#
# Option B – OpenAI API:
#   STRONG_LLM_BASE_URL=https://api.openai.com
#   STRONG_LLM_MODEL=gpt-4.1
#   STRONG_LLM_API_KEY=<OPENAI_API_KEY>
#
# Leave STRONG_LLM_BASE_URL empty to use the local LLM for everything.
STRONG_LLM_BASE_URL=
STRONG_LLM_MODEL=gpt-4.1
STRONG_LLM_API_KEY=
STRONG_LLM_TIMEOUT=120

# ── Generation ────────────────────────────────────────────────────────────
MAX_TOKENS=512
TEMPERATURE=0.3

# ── Agent behaviour ───────────────────────────────────────────────────────
THINK_INTERVAL=3.0       # seconds between autonomous think cycles
MAX_HISTORY=8            # how many past turns to include in the prompt

# ── Voyager-style improvements ────────────────────────────────────────────
MAX_RETRIES=2            # critic retry attempts per turn
CURRICULUM_INTERVAL=10   # run curriculum every N think cycles
SKILL_TOP_K=3            # how many library skills to retrieve per turn
SKILL_FAIL_THRESHOLD=3   # consecutive goal failures before skill generation triggers
SKILL_CHROMA_PATH=data/skill_chroma   # ChromaDB persistent directory

# ── Persistence ───────────────────────────────────────────────────────────
MEMORY_PATH=data/memory.json
